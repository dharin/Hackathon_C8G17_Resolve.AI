# --- Node / npm ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Next.js ---
.next/
out/
next-env.d.ts
*.tsbuildinfo
.vercel
.clerk/

# --- Python ---
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
.ipynb_checkpoints/

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.json

# --- Build output ---
dist/
build/

# --- Logs ---
logs/
*.log
# Test fixtures are real, checked-in sample logs, not runtime output.
!backend/tests/fixtures/**/*.log

# --- Agent / LLM run artifacts ---
.claude/settings.local.json
.agents/**/cache/
.agents/**/tmp/
*.session.json
*.trace.json
transcripts/
runs/
checkpoints/

# --- Vector stores / embeddings / model caches / local uploads ---
*.faiss
*.index
*.lance
lancedb/
.lancedb/
chroma/
.chroma/
.cache/
.model_cache/
*.gguf
*.safetensors
uploads/
analyses/

# RAG sync bookkeeping tracks what's in the (gitignored) lancedb/ vector
# store on THIS machine — committing it lets a new clone believe documents
# are indexed when the actual vectors never came across.
backend/data/rag_sync_state.sqlite3
backend/data/rag_sync_meta.sqlite3

# Other per-machine runtime state — committing these overwrites one
# laptop's Jira/Slack/analysis history with another's on every pull.
backend/data/analyses.sqlite3
backend/data/jira_tickets.sqlite3
backend/data/slack_notifications.sqlite3

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/*
!.vscode/extensions.json
.idea/

# --- Testing / coverage ---
coverage/
.nyc_output/

# --- Misc ---
*.tmp
*.bak
