# Copy this file to .env and fill in real values locally.
# Never commit .env or real secrets.

# --- AI (via OpenRouter — https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
# Any OpenRouter model id, e.g. "openai/gpt-4.1-mini", "anthropic/claude-3.5-sonnet".
OPENROUTER_MODEL=openai/gpt-4.1-mini

# --- Auth (Clerk) ---
# Server-only secret key (used by frontend middleware/server components and
# by the backend to fetch Clerk's JWKS for token verification). Never expose
# this to the client.
CLERK_SECRET_KEY=
# Client-safe publishable key. Must be prefixed NEXT_PUBLIC_ so Next.js
# inlines it into the browser bundle — Clerk's frontend SDK requires it there.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Backend auth ---
# "clerk" verifies real Clerk-issued bearer tokens against Clerk's JWKS.
# "mock" bypasses Clerk entirely and returns a fixed dev identity, for local
# development without a Clerk instance. Never set to "mock" outside local dev.
AUTH_PROVIDER=clerk
# Clerk Frontend API JWKS endpoint, e.g. https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# Find it in the Clerk dashboard under API Keys > Show JWT public key / Advanced.
CLERK_JWKS_URL=

# --- Frontend -> Backend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Log upload ---
# Max upload size in megabytes, enforced by both the frontend (immediate
# feedback) and the backend (source of truth). Keep these two in sync.
MAX_UPLOAD_SIZE_MB=10
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=10

# --- Confluence Cloud (RAG source) ---
CONFLUENCE_SITE_URL=https://your-site.atlassian.net
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=replace-me
CONFLUENCE_CLOUD_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Comma-separated space keys. Empty = all accessible spaces.
CONFLUENCE_INCLUDED_SPACE_KEYS=
CONFLUENCE_PAGE_LIMIT=100
CONFLUENCE_SYNC_CONCURRENCY=3

# --- Local SOP directory (RAG source) ---
LOCAL_SOP_DIRECTORY=./backend/data/sops
LOCAL_SOP_ALLOWED_EXTENSIONS=.md,.txt,.pdf,.docx
LOCAL_SOP_RECURSIVE=true

# --- RAG pipeline ---
RAG_EMBEDDING_MODEL=BAAI/bge-small-en
RAG_CHUNK_TARGET_TOKENS=650
RAG_CHUNK_MAX_TOKENS=900
RAG_CHUNK_OVERLAP_TOKENS=100
RAG_MIN_CHUNK_TOKENS=100
# "manual" for the hackathon demo, or "weekly" to enable the optional scheduler.
RAG_SYNC_SCHEDULE=manual
LANCEDB_PATH=./backend/data/lancedb
RAG_SYNC_STATE_DB_PATH=./backend/data/rag_sync_state.sqlite3

# --- Jira ---
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
