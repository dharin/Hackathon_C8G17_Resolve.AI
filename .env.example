# Copy this file to .env and fill in real values locally.
# Never commit .env or real secrets.

# --- AI ---
OPENAI_API_KEY=

# --- Auth (Clerk) ---
# Server-only secret key (used by frontend middleware/server components and
# by the backend to fetch Clerk's JWKS for token verification). Never expose
# this to the client.
CLERK_SECRET_KEY=
# Client-safe publishable key. Must be prefixed NEXT_PUBLIC_ so Next.js
# inlines it into the browser bundle — Clerk's frontend SDK requires it there.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Backend auth ---
# "clerk" verifies real Clerk-issued bearer tokens against Clerk's JWKS.
# "mock" bypasses Clerk entirely and returns a fixed dev identity, for local
# development without a Clerk instance. Never set to "mock" outside local dev.
AUTH_PROVIDER=clerk
# Clerk Frontend API JWKS endpoint, e.g. https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# Find it in the Clerk dashboard under API Keys > Show JWT public key / Advanced.
CLERK_JWKS_URL=

# --- Frontend -> Backend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Log upload ---
# Max upload size in megabytes, enforced by both the frontend (immediate
# feedback) and the backend (source of truth). Keep these two in sync.
MAX_UPLOAD_SIZE_MB=10
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=10

# --- Confluence (RAG source) ---
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_API_TOKEN=

# --- Google Drive (RAG source) ---
GOOGLE_DRIVE_CREDENTIALS=

# --- Jira ---
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
